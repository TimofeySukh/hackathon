VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Local-only LinkedIn enrichment testing. Do not set this in production.
# The Edge Function must also have LINKEDIN_ENRICHMENT_ALLOW_TEST_AUTH=true and
# LINKEDIN_ENRICHMENT_TEST_SECRET set to the same value.
VITE_LINKEDIN_ENRICHMENT_TEST_SECRET=

# Server-side AI smart search uses Supabase Edge Function secrets (not Vite).
# Provider chain (first match wins per helper/worker role): OPENAI -> GROQ -> AI_SEARCH
# Helper (nano): plan / analyze / verify — default gpt-5.4-nano on OpenAI, gpt-oss-20b on Groq
# SEARCH_HELPER_MODEL=gpt-5.4-nano
# OPENAI_HELPER_MODEL=gpt-5.4-nano
# Worker (mini): batch match — default gpt-5.4-mini on OpenAI, gpt-oss-120b on Groq fallback
# SEARCH_WORKER_MODEL=gpt-5.4-mini
# OPENAI_WORKER_MODEL=gpt-5.4-mini
# GROQ_API_KEY=gsk_...
# AI_SEARCH_API_KEY=sk-...
# AI_SEARCH_API_BASE_URL=https://api.neuraldeep.ru/v1
# AI_SEARCH_MODEL=openai/gpt-oss-120b
# OPENAI_API_KEY=sk-...

# Agent chat (OpenRouter). Test-only in the browser via Vite; move to a server secret before production.
VITE_OPENROUTER_API_KEY=
# Optional override. Default: openrouter/free (OpenRouter Free Models Router).
VITE_OPENROUTER_MODEL=openrouter/free
