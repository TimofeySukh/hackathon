name: datanode-test
region: fra

alerts:
  - rule: DEPLOYMENT_FAILED
  - rule: DOMAIN_FAILED

domains:
  - domain: __DATANODE_TEST_DOMAIN__
    type: PRIMARY
    minimum_tls_version: "1.2"

ingress:
  rules:
    - component:
        name: web
      match:
        path:
          prefix: /

services:
  - name: web
    git:
      repo_clone_url: https://github.com/TimofeySukh/hackathon.git
      branch: __DEPLOY_BRANCH__
    source_dir: /
    dockerfile_path: deploy/digitalocean-app-platform/Dockerfile
    http_port: 80
    instance_count: 1
    instance_size_slug: apps-s-1vcpu-0.5gb
    envs:
      - key: VITE_SUPABASE_URL
        value: __VITE_SUPABASE_URL__
        scope: BUILD_TIME
        type: GENERAL
      - key: VITE_SUPABASE_PUBLISHABLE_KEY
        value: __VITE_SUPABASE_PUBLISHABLE_KEY__
        scope: BUILD_TIME
        type: GENERAL
      - key: VITE_SUPABASE_ANON_KEY
        value: ""
        scope: BUILD_TIME
        type: GENERAL
